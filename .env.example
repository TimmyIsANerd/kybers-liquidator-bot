# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority

# ── Blockchain RPCs (optional — hardcoded public endpoints are used as fallback) ──
# If set, your custom RPC is tried FIRST before the built-in public endpoints.
# ETH_RPC_URL=https://your-private-eth-rpc.com
# BSC_RPC_URL=https://your-private-bsc-rpc.com

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Must be exactly 64 hex characters (32 bytes)
WALLET_ENCRYPTION_KEY=your_64_hex_char_encryption_key_here

# ── Proxy (optional, recommended for DexScreener rate limit avoidance) ────────
# Format: http://user:pass@host:port
# RESIDENTIAL_PROXY_URL=http://user:password@geo.iproyal.com:12321

# ── KyberSwap (optional) ──────────────────────────────────────────────────────
# Used as x-client-id header — no API key needed, just a descriptive name
KYBERSWAP_CLIENT_ID=kyber-liquidator-bot
